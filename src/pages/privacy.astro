---
import BaseLayout from '../layouts/BaseLayout.astro';
import Heading from '../components/Heading.astro';
import Text from '../components/Text.astro';
---

<BaseLayout title="Privacy Policy">
  <Heading as="h1" visualRank="vr1" class="mb-8">Privacy Policy</Heading>
  <Text visualRank="vr3" class="mb-4 text-gray-400">Last Updated: February 11, 2026</Text>
  <Text visualRank="vr3">
    Your privacy is important to us. This is a placeholder for the full Privacy Policy document explaining how we handle your data.
  </Text>
</BaseLayout>
