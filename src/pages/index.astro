---
import Hero from '../components/Hero.astro';
import Tutorial from '../components/Tutorial.astro';
import FrictionSection from '../components/FrictionSection.astro';
import Catalyst from '../components/Catalyst.astro';
import Connection01 from '../components/Connection01.astro';
import Connection02 from '../components/Connection02.astro';
import Connection03 from '../components/Connection03.astro';
import Connection04 from '../components/Connection04.astro';
import Axioms from '../components/Axioms.astro';
import Hub from '../components/Hub.astro';
import AboutMini from '../components/AboutMini.astro';
import Footer from '../components/Footer.astro';
import Synergize from '../components/Synergize.astro';
import Navigation from '../components/Navigation.astro';
import Navbar from '../components/Navbar.astro';
import OrbCanvas from '../components/OrbCanvas.astro';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>SoulMate Labs | Engineering Meaningful Connections</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Noto+Sans:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-midnight text-white overflow-hidden h-screen">
    <Navbar />
    
    <main class="h-full overflow-y-scroll snap-y snap-mandatory scroll-smooth" id="scroll-container">
      <Hero />
      <Tutorial />
      <FrictionSection />
      <Catalyst />
      <Connection01 />
      <Connection02 />
      <Connection03 />
      <Connection04 />
      <Axioms />
      <Hub />
      <AboutMini />
      <section id="footer" class="h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight section-module" data-index="11">
        <div class="max-w-6xl w-full flex flex-col items-center">
          <Synergize />
          <div class="w-full border-t border-white/5 my-10"></div>
          <Footer class="py-0" />
        </div>
      </section>
    </main>
    
    <Navigation />
    <OrbCanvas />

    <script>
      // Flow State Controller
      const initFlow = () => {
        const container = document.getElementById('scroll-container');
        if (!container) return;

        const sections = document.querySelectorAll('.section-module');
        const dots = document.querySelectorAll('.nav-dot');
        const upBtns = [document.getElementById('desktop-up'), document.getElementById('mobile-up')];
        const downBtns = [document.getElementById('desktop-down'), document.getElementById('mobile-down')];
        let isDirectFlow = true; // Default to Direct Flow (No Auto-Scroll) until path is selected
        let autoScrollTimer: ReturnType<typeof setTimeout> | null = null;
        let isUserInteracting = false;
        let interactionTimeout: ReturnType<typeof setTimeout> | null = null;
        let activeIndex = 0;
        let isNarrativeUnlocked = false;

        // Observer for animations and active state
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const section = entry.target as HTMLElement;
            if (entry.isIntersecting) {
              const index = parseInt(section.dataset.index || '0');
              
              // Retroactive Pixi Loading: If entering Axioms (8) or Connections, ensuring Pixi is ready
              if (index <= 8 && index >= 1 && !isNarrativeUnlocked) {
                 unlockNarrative();
              }

              // Clear any pending timer from previous section immediately upon entering a new one
              if (autoScrollTimer) clearTimeout(autoScrollTimer);

              // Manual Overwrite Check: If user scrolls UP, disable auto-scroll (Direct Flow)
              if (index < activeIndex) {
                 isDirectFlow = true;
              }
              activeIndex = index;

              // Update Nav Dots
              dots.forEach((dot) => {
                const targetId = dot.getAttribute('data-target');
                if (targetId === section.id) {
                  dot.classList.remove('bg-white/20');
                  dot.classList.add('bg-white', 'scale-125', 'shadow-[0_0_12px_rgba(147,197,253,0.8)]');
                } else {
                  dot.classList.add('bg-white/20');
                  dot.classList.remove('bg-white', 'scale-125', 'shadow-[0_0_12px_rgba(147,197,253,0.8)]');
                }
              });

              // Trigger Animations (Staccato)
              const animationDuration = animateSection(section);

              // Auto-Scroll Logic
              if (!isDirectFlow && section.dataset.autoScroll === 'true') {
                 const autoScrollWait = section.dataset.autoScrollMs ? 
                   parseInt(section.dataset.autoScrollMs) : 
                   (animationDuration + 5000);

                 console.log(`[Flow] Setting auto-scroll timer for section ${index} (${section.id}). Wait: ${autoScrollWait}ms`);

                 autoScrollTimer = setTimeout(() => {
                   console.log(`[Flow] Auto-scroll timer fired for section ${index}. isUserInteracting: ${isUserInteracting}`);
                   // Only scroll if user hasn't touched the page recently
                   if (!isUserInteracting) {
                     console.log(`[Flow] Triggering scroll to next from ${index}`);
                     scrollToNext(index);
                   } else {
                     console.log(`[Flow] Auto-scroll skipped due to user interaction`);
                   }
                 }, autoScrollWait);
              } else {
                 console.log(`[Flow] Auto-scroll not enabled for section ${index} (${section.id}). isDirectFlow: ${isDirectFlow}`);
              }
            }
          });
        }, { 
          root: container,
          threshold: 0.5 
        });

        sections.forEach(section => observer.observe(section));

        // Unlock Narrative Pipeline
        function unlockNarrative(withPixi = true) {
          if (isNarrativeUnlocked) return;
          
          console.log("[Flow] Unlocking Narrative Sections...");
          const locked = document.querySelectorAll('.narrative-locked');
          locked.forEach(el => el.classList.remove('narrative-locked'));
          
          // Step 1: Pixi initialization is now gated by 'friction-ready'
          if (withPixi) {
            window.addEventListener('friction-ready', () => {
              console.log("[Flow] Friction stable. Initializing Pixi engine...");
              window.dispatchEvent(new CustomEvent('init-pixi'));
            }, { once: true });
          }

          // Step 2: Initialize Friction visuals/logic
          (window as any).INIT_FRICTION_REQUESTED = true;
          window.dispatchEvent(new CustomEvent('init-friction'));
          
          isNarrativeUnlocked = true;
        }

        // Animation Helper - returns total animation duration in ms
        function animateSection(section: HTMLElement): number {
          let maxDelay = 0;
          const heroElements = [
            document.getElementById('hero-brand'),
            document.getElementById('hero-seo'), 
            document.getElementById('hero-hook'), 
            document.getElementById('hero-actions')
          ];

          if (section.id === 'command-center') {
             heroElements.forEach((el, i) => {
                if(el && !el.classList.contains('animate-fade-in-up')) {
                  const delay = i * 200;
                  maxDelay = Math.max(maxDelay, delay);
                  setTimeout(() => {
                    el.classList.remove('opacity-0', 'translate-y-4');
                    el.classList.add('animate-fade-in-up');
                  }, delay);
                }
             });
          } else {
            // Visual Asset Animation
            const visualAnimations: Record<string, { id: string, className: string, delay: number }> = {
              'friction-state': { id: 'friction-collage', className: 'animate-chaos-shimmer', delay: 400 },
              'connection-01': { id: 'connection-01-visual', className: 'animate-fade-in', delay: 400 },
              'connection-02': { id: 'connection-02-visual', className: 'animate-elliptical-grow', delay: 400 },
              'connection-03': { id: 'connection-03-visual', className: 'animate-reveal-down', delay: 400 },
              'connection-04': { id: 'connection-04-visual', className: 'animate-reveal-right', delay: 400 },
            };

            const visual = visualAnimations[section.id];
            if (visual) {
              const el = document.getElementById(visual.id);
              if (el && !el.classList.contains(visual.className)) {
                setTimeout(() => {
                  el.classList.remove('opacity-0');
                  el.classList.add(visual.className);
                }, visual.delay);
              }
            }

            const elements = section.querySelectorAll('.staccato-text');
            elements.forEach((el, i) => {
               const htmlEl = el as HTMLElement;
               if (htmlEl.classList.contains('animate-fade-in-up')) return;
               
               const customDelay = parseInt(htmlEl.dataset.delay || '0');
               const isAbsolute = htmlEl.dataset.delayAbsolute === 'true';
               const delay = isAbsolute ? customDelay : (i * 1000) + customDelay;
               
               maxDelay = Math.max(maxDelay, delay);
               setTimeout(() => {
                 htmlEl.classList.remove('opacity-0', 'translate-y-4');
                 htmlEl.classList.add('animate-fade-in-up');
               }, delay);
            });
          }
          return maxDelay + 1000;
        }

        function scrollToNext(currentIndex: number) {
          if (currentIndex < sections.length - 1) {
            sections[currentIndex + 1].scrollIntoView({ behavior: 'smooth' });
          }
        }
        
        function scrollToPrev(currentIndex: number) {
           if (currentIndex > 0) {
            sections[currentIndex - 1].scrollIntoView({ behavior: 'smooth' });
          }
        }

        // Navigation Buttons
        const handleNavClick = (direction: 'up' | 'down') => {
          isUserInteracting = true;
          if(autoScrollTimer) clearTimeout(autoScrollTimer);
          
          let currentIndex = 0;
          let minDistance = Infinity;
          
          sections.forEach((s, i) => {
            // Check if section is visible in layout (skip display: none)
            if ((s as HTMLElement).offsetParent === null) return;

            const rect = s.getBoundingClientRect();
            const distance = Math.abs(rect.top);
            if (distance < minDistance) {
              minDistance = distance;
              currentIndex = i;
            }
          });

          // Retroactive unlock if trying to go into narrative zone
          if (!isNarrativeUnlocked) {
             if ((direction === 'down' && currentIndex === 0) || 
                 (direction === 'up' && currentIndex === 9)) {
                unlockNarrative(true);
                // Give layout a moment to reflow before calculating target
                setTimeout(() => {
                  if (direction === 'up') scrollToPrev(currentIndex);
                  else scrollToNext(currentIndex);
                }, 10);
                return;
             }
          }

          if (direction === 'up') scrollToPrev(currentIndex);
          else scrollToNext(currentIndex);

          // Reset interaction after 5s of no activity from nav buttons
          resetInteractionDelay();
        };

        upBtns.forEach(btn => btn?.addEventListener('click', () => handleNavClick('up')));
        downBtns.forEach(btn => btn?.addEventListener('click', () => handleNavClick('down')));

        // Nav Dot Unlocking
        dots.forEach(dot => {
          dot.addEventListener('click', () => {
            if (!isNarrativeUnlocked) {
              unlockNarrative(true);
            }
          });
        });

        // User Interaction Listener
        const recordInteraction = () => {
          isUserInteracting = true;
          if (autoScrollTimer) clearTimeout(autoScrollTimer);
          resetInteractionDelay();
        };

        const resetInteractionDelay = () => {
          if (interactionTimeout) clearTimeout(interactionTimeout);
          interactionTimeout = setTimeout(() => {
            isUserInteracting = false;
          }, 5000); // Resume auto-scroll logic after 5s of idleness
        };

        ['mousedown', 'wheel', 'touchstart', 'keydown'].forEach(evt => {
          container?.addEventListener(evt, recordInteraction, { passive: true });
        });

        // Flow Logic (Direct vs Narrative)
        const narrativeBtn = document.querySelector('.btn-narrative');
        const directBtn = document.querySelector('.btn-direct');

        const unlockAudio = () => {
          // Create a silent buffer to unlock audio on mobile/desktop
          const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
          if (AudioContext) {
            const ctx = new AudioContext();
            ctx.resume();
          }
          
          // Proactively unmute on first "Begin" if not set
          if (localStorage.getItem('isMuted') === null) {
            localStorage.setItem('isMuted', 'false');
            // Re-trigger UI update in Navigation
            window.dispatchEvent(new CustomEvent('audioStateChanged', { detail: { isMuted: false } }));
          }

          // Show the mute button globally
          window.dispatchEvent(new CustomEvent('showMuteButton'));
        };

        // Path 1: Begin Journey
        narrativeBtn?.addEventListener('click', (e) => {
          e.preventDefault();
          unlockNarrative(true);
          isDirectFlow = false;
          isUserInteracting = false; // Reset to allow auto-scroll to start on FrictionSection
          if (interactionTimeout) clearTimeout(interactionTimeout);
          unlockAudio();
          
          // Manual scroll after unlock to ensure layout is ready
          setTimeout(() => {
            const target = document.getElementById('tutorial');
            target?.scrollIntoView({ behavior: 'smooth' });
          }, 10);
        });

        // Prewarming Path 1 (Friction Assets)
        ['mouseenter', 'touchstart'].forEach(evt => {
          narrativeBtn?.addEventListener(evt, () => {
             window.dispatchEvent(new CustomEvent('warm-friction'));
          }, { once: true });
        });

        // Path 2: Explore Apps
        directBtn?.addEventListener('click', (e) => {
          e.preventDefault();
          // DO NOT unlock narrative here to keep Explore Apps path clean
          isDirectFlow = true;
          unlockAudio();
          
          const target = document.getElementById('hub');
          target?.scrollIntoView({ behavior: 'smooth' });
        });

        // Shy CTA Logic (Item 15 & 17)
        const shyBtns = document.querySelectorAll('.shy-cta');
        shyBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const app = (e.currentTarget as HTMLElement).dataset.app;
            const targetUrl = (e.currentTarget as HTMLElement).getAttribute('data-url') || `/${app}`;
            
            // 1. Pause Auto-Scroll
            isUserInteracting = true;
            if (autoScrollTimer) clearTimeout(autoScrollTimer);
            
            // 2. Smooth Scroll to Hub
            const hubSection = document.getElementById('hub');
            if (hubSection) {
              hubSection.scrollIntoView({ behavior: 'smooth' });
              
              // 3. Trigger illumination upon arrival and delayed window open
              setTimeout(() => {
                const card = document.getElementById(`hub-card-${app}`);
                if (card) {
                  // Illuminate card immediately upon arrival
                  card.classList.add('hub-card-illuminate');
                  
                  // 4. Open external link after a 2-second delay
                  setTimeout(() => {
                    window.open(targetUrl, '_blank');
                  }, 2000);
                  
                  // Remove illumination after a total of 5 seconds
                  setTimeout(() => {
                    card.classList.remove('hub-card-illuminate');
                  }, 5000);
                }
              }, 1200); // Wait for scroll-to-Hub to complete
            }
          });
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFlow);
      } else {
        initFlow();
      }
    </script>

    <style is:global>
      /* Utility for hiding scrollbar but allowing scroll */
      #scroll-container::-webkit-scrollbar {
        display: none; 
      }
      #scroll-container {
        -ms-overflow-style: none;
        scrollbar-width: none;
        
        /* Ensure stacking context for animations */
        position: relative;
        z-index: 10;
      }
      
      /* Transparency for Background Animations */
      .section-module:not(#command-center):not(#axioms):not(#hub):not(#about-mini):not(#footer) {
        background-color: transparent !important;
      }

      .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
      }
      @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
      }
    </style>
	</body>
</html>
