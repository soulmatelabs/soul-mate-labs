---
import BaseLayout from '../layouts/BaseLayout.astro';
import Heading from '../components/Heading.astro';
import Text from '../components/Text.astro';
---

<BaseLayout title="About Us">
  <Heading as="h1" visualRank="vr1" class="mb-8">About Us</Heading>
  <Text visualRank="vr2" class="mb-6">
    SoulMate Labs is dedicated to creating mindful social technology that fosters authentic human connection in an increasingly digital world.
  </Text>
  <Text visualRank="vr3">
    We believe that technology should serve humanity, not the other way around. Our mission is to build tools that help people find depth, clarity, and genuine resonance in their relationships.
  </Text>
</BaseLayout>
