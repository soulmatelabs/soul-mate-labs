---
import BaseLayout from '../layouts/BaseLayout.astro';
import Heading from '../components/Heading.astro';
import Text from '../components/Text.astro';
---

<BaseLayout title="Terms of Service">
  <Heading as="h1" visualRank="vr1" class="mb-8">Terms of Service</Heading>
  <Text visualRank="vr3" class="mb-4 text-gray-400">Last Updated: February 11, 2026</Text>
  <Text visualRank="vr3">
    By using our services, you agree to follow our terms. This is a placeholder for the full Terms of Service document.
  </Text>
</BaseLayout>
