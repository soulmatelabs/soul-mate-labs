---
import BaseLayout from '../layouts/BaseLayout.astro';
import Heading from '../components/Heading.astro';
import Text from '../components/Text.astro';
---

<BaseLayout title="Careers">
  <Heading as="h1" visualRank="vr1" class="mb-8">Careers</Heading>
  <Text visualRank="vr2" class="mb-6">
    Join us in redefining the future of human connection.
  </Text>
  <Text visualRank="vr3">
    We are always looking for passionate individuals who care about the intersection of technology, psychology, and authentic living. Stay tuned for open positions.
  </Text>
</BaseLayout>
