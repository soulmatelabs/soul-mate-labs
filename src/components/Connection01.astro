---
import Heading from './Heading.astro';
import Text from './Text.astro';

// Component: Connection01 (Module 04)
// Physics: Full-Screen | Snap-Point
---
<section id="connection-01" class="h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight text-center p-8 section-module" data-index="3" data-auto-scroll="true">
  <div class="w-48 h-48 sm:w-64 sm:h-64 mb-12 relative flex justify-center items-center">
    <div class="absolute inset-0 bg-lunar/20 blur-3xl rounded-full animate-pulse-slow"></div>
    <img 
      id="connection-01-visual"
      src="/assets/splorer-orb.svg" 
      alt="A glowing blue orb representing self-discovery and internal clarity." 
      class="relative w-full h-full object-contain opacity-0" 
    />
  </div>

  <Heading as="h2" visualRank="vr1" class="mb-6 opacity-0 translate-y-4 staccato-text">
    Connection 1.0: Know yourself.
  </Heading>
  
  <Text visualRank="vr2" class="max-w-md opacity-0 translate-y-4 staccato-text">
    You cannot connect outward until you connect inward.
  </Text>

  <button 
    class="shy-cta opacity-0 translate-y-4 staccato-text" 
    data-app="SoulSight"
    aria-label="Seek Clarity with SoulSight"
  >
    Seek Clarity
  </button>
</section>
