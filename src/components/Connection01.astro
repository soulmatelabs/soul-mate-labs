---
import Heading from './Heading.astro';
import Text from './Text.astro';

// Component: Connection01 (Module 04)
// Physics: Full-Screen | Snap-Point
---
<section 
  id="connection-01" 
  class="h-screen w-full snap-start flex flex-col justify-center items-center text-center p-8 section-module narrative-locked" 
  data-index="3" 
  data-auto-scroll="true"
  data-auto-scroll-ms="12000"
  data-hands-duration="2500"
>
  <div class="h-64 w-full"></div> {/* Spacer to maintain text position roughly */}

  <Heading 
    as="h2" 
    visualRank="vr1" 
    class="mb-6 opacity-0 translate-y-4 staccato-text"
    data-delay="0"
    data-delay-absolute="true"
  >
    Connection 1.0: Know yourself.
  </Heading>
  
  <Text 
    visualRank="vr2" 
    class="max-w-md opacity-0 translate-y-4 staccato-text"
    data-delay="7000"
    data-delay-absolute="true"
  >
    You cannot connect outward until you connect inward.
  </Text>

  <button 
    class="shy-cta opacity-0 translate-y-4 staccato-text" 
    data-app="SoulSight"
    data-delay="10000"
    data-delay-absolute="true"
    aria-label="Seek Clarity with SoulSight"
  >
    Seek Clarity
  </button>
</section>
