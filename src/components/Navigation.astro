---
// Component: Navigation (Nav FAB)
// Desktop: Right side dots
// Mobile: Bottom right FABs (Up/Down)
---
<!-- Desktop Navigation -->
<div class="nav-desktop fixed right-8 top-1/2 -translate-y-1/2 z-50 flex flex-col items-center space-y-4">
  <button aria-label="Scroll Up" class="p-2 text-lunar/50 hover:text-lunar transition-colors" id="desktop-up">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
  
  <nav class="flex flex-col space-y-3">
    {[
      { id: 'command-center', label: 'Go to Top / Introduction' },
      { id: 'tutorial', label: 'Go to Interface Guide' },
      { id: 'friction-state', label: 'Go to The Problem (Noise)' },
      { id: 'catalyst', label: 'Go to Our Solution' },
      { id: 'connection-01', label: 'Explore Connection Level 1' },
      { id: 'connection-02', label: 'Explore Connection Level 2' },
      { id: 'connection-03', label: 'Explore Connection Level 3' },
      { id: 'connection-04', label: 'Explore Connection Level 4' },
      { id: 'axioms', label: 'Go to Invitation' },
      { id: 'hub', label: 'Explore Our Applications' },
      { id: 'about-mini', label: 'Go to Our Team Philosophy' },
      { id: 'footer', label: 'Footer / Social Links' }
    ].map((item) => (
      <a 
        href={`#${item.id}`} 
        aria-label={item.label}
        class="w-2 h-2 rounded-full bg-white/20 hover:bg-lunar hover:scale-125 transition-all nav-dot relative"
        data-target={item.id}
      >
        <span class="absolute inset-[-20px] cursor-pointer"></span>
      </a>
    ))}
  </nav>
  
  <button aria-label="Scroll Down" class="p-2 text-lunar/50 hover:text-lunar transition-colors" id="desktop-down">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </button>
</div>

<!-- Mobile Navigation (Two FABs) -->
<div class="nav-mobile fixed right-4 bottom-4 z-50 flex flex-col space-y-2">
  <button aria-label="Scroll Up" class="p-3 bg-surface/80 backdrop-blur border border-white/10 rounded-full text-lunar hover:bg-lunar hover:text-midnight transition-colors shadow-lg" id="mobile-up">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
  <button aria-label="Scroll Down" class="p-3 bg-surface/80 backdrop-blur border border-white/10 rounded-full text-lunar hover:bg-lunar hover:text-midnight transition-colors shadow-lg" id="mobile-down">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </button>
</div>

<style>
  /* Default: Mobile style */
  .nav-desktop {
    display: none;
  }
  .nav-mobile {
    display: flex;
  }

  /* Desktop/Horizontal Tablet: Desktop style */
  @media (min-width: 1024px), (min-width: 768px) and (orientation: landscape) {
    .nav-desktop {
      display: flex;
    }
    .nav-mobile {
      display: none;
    }
  }
</style>

<!-- Audio Toggle (Item 18) -->
<div id="audio-toggle-container" class="fixed bottom-6 left-6 z-50 opacity-0 pointer-events-none transition-opacity duration-700">
  <button id="audio-toggle" aria-label="Toggle Sound" class="p-3 bg-surface/80 backdrop-blur border border-white/10 rounded-full text-lunar shadow-lg active:scale-95 transition-all flex items-center justify-center">
    <div id="audio-icon-on" class="hidden">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5Z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
    </div>
    <div id="audio-icon-off">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5Z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
    </div>
  </button>
</div>

<script>
  // Audio Toggle Logic
  const audioToggle = document.getElementById('audio-toggle');
  const toggleContainer = document.getElementById('audio-toggle-container');
  const iconOn = document.getElementById('audio-icon-on');
  const iconOff = document.getElementById('audio-icon-off');
  
  let isMuted = localStorage.getItem('isMuted') !== 'false'; // Default to muted

  const updateUI = () => {
    if (isMuted) {
      iconOn?.classList.add('hidden');
      iconOff?.classList.remove('hidden');
    } else {
      iconOn?.classList.remove('hidden');
      iconOff?.classList.add('hidden');
    }
  };

  // Initialize UI
  updateUI();

  // Show mute button when gesture is performed
  window.addEventListener('showMuteButton', () => {
    toggleContainer?.classList.remove('opacity-0', 'pointer-events-none');
  });

  // Listen for external state changes (e.g. from Hero buttons)
  window.addEventListener('audioStateChanged', (e: any) => {
    if (isMuted !== e.detail.isMuted) {
      isMuted = e.detail.isMuted;
      updateUI();
    }
  });

  audioToggle?.addEventListener('click', () => {
    isMuted = !isMuted;
    localStorage.setItem('isMuted', isMuted.toString());
    updateUI();
    // Dispatch custom event for other components to listen to
    window.dispatchEvent(new CustomEvent('audioStateChanged', { detail: { isMuted } }));
  });
</script>
