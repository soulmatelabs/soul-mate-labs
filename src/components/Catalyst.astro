---
import Heading from './Heading.astro';
import Text from './Text.astro';

// Component: Catalyst (Module 03)
// Physics: Full-Screen | Snap-Point
---
<section id="catalyst" class="h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight text-center p-8 section-module" data-index="2" data-auto-scroll="true">
  <Heading as="h2" visualRank="vr1" class="mb-8 max-w-4xl opacity-0 translate-y-4 staccato-text">
    Connection is a process, not a platform.
  </Heading>
  
  <Text visualRank="vr2" class="max-w-xl opacity-0 translate-y-4 staccato-text">
    From isolation to connection, the journey starts within.
  </Text>
</section>
