---
import Heading from './Heading.astro';
import Text from './Text.astro';

// Component: FrictionState (Module 02)
// Physics: Full-Screen | Snap-Point
---
<section id="friction-state" class="h-screen w-full snap-start flex justify-center items-center bg-midnight overflow-hidden p-8 relative section-module" data-index="1" data-auto-scroll="true">
  <div id="friction-chaos" class="absolute inset-0 z-0 opacity-0 pointer-events-none select-none">
     <img 
      src="/assets/chaos-blur.svg" 
      alt="A chaotic blur of social media notifications representing digital noise." 
      class="w-full h-full object-cover"
    />
  </div>

  <div class="relative z-10 text-center">
    <Heading as="h2" visualRank="vr1" class="mb-6 opacity-0 translate-y-4 staccato-text">
      The noise is deafening.
    </Heading>
    <Text visualRank="vr2" class="opacity-0 translate-y-4 staccato-text" data-delay="500">
      Escape the noise. Start connecting.
    </Text>
  </div>
</section>
