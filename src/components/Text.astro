---
import type { HTMLTag } from 'astro/types';

export interface Props {
  as?: HTMLTag;
  visualRank?: 'vr2' | 'vr3' | 'vr4' | 'vr5';
  class?: string;
  id?: string;
}

const { as: Tag = 'p', visualRank = 'vr3', class: className, id, ...rest } = Astro.props;

const rankStyles: Record<'vr2' | 'vr3' | 'vr4' | 'vr5', string> = {
  vr2: 'text-lg sm:text-xl md:text-2xl font-body text-content-body leading-relaxed',
  vr3: 'text-sm sm:text-base md:text-lg font-body text-content-body/80 leading-relaxed',
  vr4: 'text-xs sm:text-sm font-body text-content-muted leading-snug',
  vr5: 'text-xs font-sans text-content-muted uppercase tracking-widest',
};
---

<Tag id={id} class:list={[rankStyles[visualRank as keyof typeof rankStyles], className]} {...rest}>
  <slot />
</Tag>