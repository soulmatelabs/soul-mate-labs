---
import { Image } from 'astro:assets';
import Heading from './Heading.astro';
import Text from './Text.astro';
import up4itLogo from '../assets/Up4it-logo-medium.webp';
import couplairLogo from '../assets/Couplair-logo-medium.webp';
import soulsightLogo from '../assets/SoulSight-Logo.svg';

// Component: Hub (Module 09)
// Physics: Min-Height Screen | Snap-Point
---
<section id="hub" class="min-h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight p-8 text-center relative section-module" data-index="8">
  <div class="flex-grow flex flex-col justify-center items-center w-full py-20">
    <Heading as="h2" visualRank="vr1" class="mb-16 opacity-0 translate-y-4 staccato-text">
      Begin your journey.
    </Heading>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 w-full max-w-7xl opacity-0 translate-y-4 staccato-text">
      <a id="hub-card-soulsight" href="https://soulmatelabs.github.io/soulsight-site/" target="_blank" class="hub-card h-full p-4 md:p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-white rounded-full mb-6 group-hover:bg-white/90 transition-colors flex items-center justify-center p-3">
          <Image src={soulsightLogo} alt="SoulSight Logo" width={64} height={64} loading="lazy" class="max-w-full max-h-full object-contain" />
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">SoulSight</Heading>
        <Text visualRank="vr4" class="mb-6 flex-grow">Know yourself deeper through enhanced journaling and AI-aided self-reflection.</Text>
        <span class="hidden md:inline-block px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Reflect in SoulSight</span>
      </a>
      
      <a id="hub-card-up4it" href="https://soulmatelabs.github.io/up4it-site/" target="_blank" class="hub-card h-full p-4 md:p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-white rounded-full mb-6 group-hover:bg-white/90 transition-colors flex items-center justify-center p-2 overflow-hidden">
          <Image src={up4itLogo} alt="Up4it Logo" width={64} height={64} loading="lazy" class="max-w-full max-h-full object-contain" />
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Up4it</Heading>
        <Text visualRank="vr4" class="mb-6 flex-grow">Painless friendship maintenance for spontaneous, friction-free, and memorable moments.</Text>
        <span class="hidden md:inline-block px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Connect with Up4it</span>
      </a>
      
      <a id="hub-card-soulmate" href="https://soulmatelabs.github.io/soul-mate-site/" target="_blank" class="hub-card h-full p-4 md:p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-lunar/20 rounded-full mb-6 group-hover:bg-lunar/40 transition-colors flex items-center justify-center">
          <div class="w-10 h-0.5 bg-lunar"></div>
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Soul Mate</Heading>
        <Text visualRank="vr4" class="mb-6 flex-grow">Forge relationships that transcend the superficial and resonate at depth.</Text>
        <span class="hidden md:inline-block px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Find Soul Mate</span>
      </a>
      
      <a id="hub-card-couplair" href="https://soulmatelabs.github.io/couplair-site/" target="_blank" class="hub-card h-full p-4 md:p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-white rounded-full mb-6 group-hover:bg-white/90 transition-colors flex items-center justify-center p-3">
          <Image src={couplairLogo} alt="Couplair Logo" width={64} height={64} loading="lazy" class="max-w-full max-h-full object-contain" />
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Couplair</Heading>
        <Text visualRank="vr4" class="mb-6 flex-grow">Help your partner understand your timing and needs, with zero drama.</Text>
        <span class="hidden md:inline-block px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Sync with Couplair</span>
      </a>
    </div>
  </div>
</section>
