---
import { Image } from 'astro:assets';
import Heading from './Heading.astro';
import Text from './Text.astro';
import up4itLogo from '../assets/Up4it-logo-medium.webp';
import couplairLogo from '../assets/Couplair-logo-medium.webp';

// Component: Hub (Module 09)
// Physics: Min-Height Screen | Snap-Point
---
<section id="hub" class="min-h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight p-8 text-center relative section-module" data-index="8">
  <div class="flex-grow flex flex-col justify-center items-center w-full py-20">
    <Heading as="h2" visualRank="vr1" class="mb-16 opacity-0 translate-y-4 staccato-text">
      Begin your journey.
    </Heading>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-7xl opacity-0 translate-y-4 staccato-text">
      <a id="hub-card-splorer" href="/splorer" target="_blank" class="hub-card p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-lunar/20 rounded-full mb-6 group-hover:bg-lunar/40 transition-colors flex items-center justify-center">
          <div class="w-8 h-8 bg-lunar rounded-full animate-pulse"></div>
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Splorer</Heading>
        <Text visualRank="vr4" class="mb-6 h-12">Know yourself deeper through enhanced journaling and AI-aided self-reflection.</Text>
        <span class="px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Discover with Splorer</span>
      </a>
      
      <a id="hub-card-up4it" href="/up4it" target="_blank" class="hub-card p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-lunar/20 rounded-full mb-6 group-hover:bg-lunar/40 transition-colors flex items-center justify-center overflow-hidden">
          <Image src={up4itLogo} alt="Up4it Logo" width={64} height={64} class="w-10 h-10 object-contain" />
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Up4it</Heading>
        <Text visualRank="vr4" class="mb-6 h-12">Painless friendship maintenance for spontaneous, friction-free, and memorable moments.</Text>
        <span class="px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Connect with Up4it</span>
      </a>
      
      <a id="hub-card-soulmate" href="/soulmate" target="_blank" class="hub-card p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-lunar/20 rounded-full mb-6 group-hover:bg-lunar/40 transition-colors flex items-center justify-center">
          <div class="w-10 h-0.5 bg-lunar"></div>
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Soul Mate</Heading>
        <Text visualRank="vr4" class="mb-6 h-12">Forge relationships that transcend the superficial and resonate at depth.</Text>
        <span class="px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Find Soul Mate</span>
      </a>
      
      <a id="hub-card-couplair" href="/couplair" target="_blank" class="hub-card p-8 bg-surface border border-white/5 rounded-2xl flex flex-col items-center hover:border-lunar transition-all duration-300 group">
        <div class="w-16 h-16 bg-lunar/20 rounded-full mb-6 group-hover:bg-lunar/40 transition-colors flex items-center justify-center overflow-hidden">
          <Image src={couplairLogo} alt="Couplair Logo" width={64} height={64} class="w-10 h-10 object-contain" />
        </div>
        <Heading as="h3" visualRank="vr3" class="mb-3">Couplair</Heading>
        <Text visualRank="vr4" class="mb-6 h-12">Help your partner understand your timing and needs, with zero drama.</Text>
        <span class="px-6 py-2 border border-lunar/30 rounded-full text-lunar/60 text-xs tracking-widest uppercase group-hover:border-lunar group-hover:text-lunar transition-colors">Sync with Couplair</span>
      </a>
    </div>
  </div>
</section>
