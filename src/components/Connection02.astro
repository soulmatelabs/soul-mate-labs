---
import Heading from './Heading.astro';
import Text from './Text.astro';

// Component: Connection02 (Module 05)
// Physics: Full-Screen | Snap-Point
---
<section 
  id="connection-02" 
  class="h-screen w-full snap-start flex flex-col justify-center items-center text-center p-8 overflow-hidden section-module narrative-locked" 
  data-index="5" 
  data-auto-scroll="true"
  data-auto-scroll-ms="8500"
  data-animation-delay="3000"
>
  {/* Visual: Ripples (Replaced by PIXI)
  <div id="connection-02-visual" class="absolute inset-0 flex justify-center items-center z-0 opacity-0 pointer-events-none">
    <img 
      src="/assets/lunar-ripples.svg" 
      alt="Abstract ripples in lunar blue representing expanding social circles." 
      class="w-full h-full object-cover" 
    />
  </div>
  */}

  <div class="h-64 w-full"></div> {/* Spacer to maintain text position roughly */}

  <Heading 
    as="h2" 
    visualRank="vr1" 
    class="mb-6 opacity-0 translate-y-4 staccato-text"
    data-delay="0"
    data-delay-absolute="true"
  >
    Connection 2.0: Nurture your circle.
  </Heading>

  <Text 
    visualRank="vr2" 
    class="max-w-md mx-auto opacity-0 translate-y-4 staccato-text"
    data-delay="4000"
    data-delay-absolute="true"
  >
    Moments that matter, without the friction.
  </Text>

  <button 
    class="shy-cta opacity-0 translate-y-4 staccato-text mx-auto" 
    data-app="up4it"
    data-url="https://soulmatelabs.github.io/up4it-site/"
    data-delay="7000"
    data-delay-absolute="true"
    aria-label="Circle Up with Up4it"
  >
    Circle Up
  </button>
</section>