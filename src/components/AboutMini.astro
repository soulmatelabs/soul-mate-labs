---
import Heading from './Heading.astro';
import Text from './Text.astro';
---

<section id="about-mini" class="min-h-screen w-full snap-start flex flex-col justify-center items-center bg-midnight section-module px-8" data-index="10">
    <div class="max-w-3xl mx-auto w-full text-center">
        
        <!-- [ST: H2 | VR: VR3] Section Label -->
        <div class="staccato-text opacity-0 translate-y-4 mb-6" data-delay="0">
            <Heading as="h2" visualRank="vr3" class="text-lunar uppercase tracking-[0.3em]">
                Our Convictions
            </Heading>
        </div>

        <!-- [ST: H3 | VR: VR1] The Hook -->
        <div class="staccato-text opacity-0 translate-y-4 mb-10" data-delay="200">
            <Heading as="h3" visualRank="vr1" class="leading-tight">
                You're interesting enough. <br class="hidden md:block" /> <span class="text-lunar">Stop performing.</span>
            </Heading>
        </div>

        <!-- [ST: P | VR: VR2] Context Body: Scaled up for readability -->
        <div class="staccato-text opacity-0 translate-y-4" data-delay="400">
            <Text visualRank="vr2" class="max-w-2xl mx-auto">
                Socializing shouldn't feel like a side hustle or a stage play. It should just click. Everything we build is designed to help you effortlessly fit where and with whom you belong.
            </Text>
        </div>

        <!-- [ST: A | VR: Action] Shy CTA Look -->
        <div class="staccato-text opacity-0 translate-y-4" data-delay="600">
            <a href="/about" class="btn-shy inline-block !mt-12">
                More About Us
            </a>
        </div>

    </div>
</section>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
    .animate-float {
        animation: float 6s ease-in-out infinite;
    }
</style>
