---
import type { HTMLTag } from 'astro/types';

export interface Props {
  as?: HTMLTag;
  visualRank: 'vr1' | 'vr2' | 'vr3';
  class?: string;
  id?: string;
}

const { as: Tag = 'h2', visualRank, class: className, id } = Astro.props;

const rankStyles: Record<'vr1' | 'vr2' | 'vr3', string> = {
  vr1: 'text-4xl sm:text-5xl md:text-7xl font-bold font-sans tracking-tighter leading-none text-white',
  vr2: 'text-2xl md:text-4xl font-medium font-body tracking-wide text-gray-200',
  vr3: 'text-xs sm:text-sm font-semibold font-sans uppercase tracking-[0.2em] text-lunar',
};
---

<Tag id={id} class:list={[rankStyles[visualRank as keyof typeof rankStyles], className]}>
  <slot />
</Tag>